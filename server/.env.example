GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret
SESSION_SECRET=my-super-secret-long-string-here
# In production keep SESSION_SECRET stable; do not rotate accidentally between deploys.
# First URL is used for OAuth redirects; comma-separate to allow multiple origins in CORS (e.g. https://trueprice.cash,https://www.trueprice.cash).
CLIENT_URL=http://localhost:5173
# Optional: extra allowed CORS origins (comma-separated). TruePrice production domains are also built into server.js.
# CORS_EXTRA_ORIGINS=https://staging.example.com
# Public URL of this API (https). Used for Google callbackURL. Must match what you set as VITE_API_URL on Cloudflare.
SERVER_URL=http://localhost:3001
# SQLite database file path. On Render persistent disk, use: /var/data/trueprice.db
# DB_PATH=/var/data/trueprice.db
# Redis URL for persistent sessions (recommended on Render/Upstash).
# REDIS_URL=redis://default:password@host:port
# Canonical domain redirect (default trueprice.cash). Requests to www are redirected here.
# CANONICAL_HOST=trueprice.cash
# Optional extra hosts to 301 to CANONICAL_HOST (comma-separated, hostnames only).
# CANONICAL_ALIASES=www.trueprice.cash
# Set FORCE_CANONICAL_HOST=false to disable canonical host redirects.
# FORCE_CANONICAL_HOST=true
# Optional: enforce one active session per user; new login invalidates old sessions.
# SINGLE_SESSION_PER_USER=false
# Optional: force session cookie SameSite (none | lax | strict). If unset, production uses "none" when CLIENT_URL and SERVER_URL differ (e.g. Cloudflare + Railway).
# SESSION_COOKIE_SAMESITE=
