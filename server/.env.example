GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret
SESSION_SECRET=my-super-secret-long-string-here
# First URL is used for OAuth redirects; comma-separate to allow multiple origins in CORS (e.g. https://trueprice.cash,https://www.trueprice.cash).
CLIENT_URL=http://localhost:5173
# Optional: extra allowed CORS origins (comma-separated). TruePrice production domains are also built into server.js.
# CORS_EXTRA_ORIGINS=https://staging.example.com
# Public URL of this API (https). Used for Google callbackURL. Must match what you set as VITE_API_URL on Cloudflare.
SERVER_URL=http://localhost:3001
# Optional: force session cookie SameSite (none | lax | strict). If unset, production uses "none" when CLIENT_URL and SERVER_URL differ (e.g. Cloudflare + Railway).
# SESSION_COOKIE_SAMESITE=
