GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret
SESSION_SECRET=my-super-secret-long-string-here
# First URL is used for OAuth redirects; comma-separate to allow multiple dev ports. Non-prod also allows any localhost port in CORS.
CLIENT_URL=http://localhost:5173
SERVER_URL=http://localhost:3001
