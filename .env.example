# TwelveData API (required for stock data)
VITE_TWELVEDATA_API_KEY=your-api-key

# Optional: Web3Forms for contact form
VITE_WEB3FORMS_KEY=
VITE_WEB3FORMS_TO=

# Optional: Prefetch delay in ms (default 5000)
VITE_PREFETCH_DELAY_MS=5000

# Optional: Blogger for blogs
VITE_BLOGGER_BLOG_ID=
VITE_BLOGGER_API_KEY=

# API server URL (for auth, comments, watchlists, portfolio)
# Local: http://localhost:3001 when the Express server runs locally.
# Vercel/production: set to your deployed API base URL (https://...), not localhost.
# If unset in production builds, the app uses the site origin (same host as the static app).
VITE_API_URL=http://localhost:3001
