# TwelveData API (required for stock data)
VITE_TWELVEDATA_API_KEY=your-api-key

# Optional: Web3Forms for contact form
VITE_WEB3FORMS_KEY=
VITE_WEB3FORMS_TO=

# Optional: Prefetch delay in ms (default 5000)
VITE_PREFETCH_DELAY_MS=5000

# Blogger (blogs page) — NOT the same as Google OAuth for sign-in.
# Blog ID: Blogger admin → Settings, or from your blog URL. API key: Google Cloud → APIs → Credentials → API key with Blogger API v3 enabled.
VITE_BLOGGER_BLOG_ID=
VITE_BLOGGER_API_KEY=

# API base URL for the browser (auth, comments, watchlists). OAuth client ID/secret stay on the server (GOOGLE_* in server/.env).
# Local: http://localhost:3001
# Static host + separate API: https://your-api.onrender.com
# Single deploy (same URL for site + API): leave empty — the app uses the page origin.
VITE_API_URL=http://localhost:3001
